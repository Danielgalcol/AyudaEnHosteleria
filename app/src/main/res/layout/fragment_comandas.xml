                            android:contentDescription="Quitar" />

                        <TextView
                            android:id="@+id/tvCantidad12"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="#212121"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <ImageButton
                            android:id="@+id/btnMas12"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/circle_button_green"
                            android:contentDescription="Añadir" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!--BEBIDA 13-->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="2dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nestea"
                                android:textColor="#212121"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2,80 €"
                                android:textColor="#757575"
                                android:textSize="14sp" />
                        </LinearLayout>

                        <ImageButton
                            android:id="@+id/btnMenos13"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/circle_button_red"
                            android:contentDescription="Quitar" />

                        <TextView
                            android:id="@+id/tvCantidad13"
                            android:layout_width="40dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="0"
                            android:textColor="#212121"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <ImageButton
                            android:id="@+id/btnMas13"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/circle_button_green"
                            android:contentDescription="Añadir" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ALERGIAS -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="8dp"
                    android:text="Alergias"
                    android:textColor="#212121"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/cbGluten"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Gluten" />

                    <CheckBox
                        android:id="@+id/cbLactosa"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Lactosa" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/cbFrutosSec"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Frutos secos" />

                    <CheckBox
                        android:id="@+id/cbMariscos"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Mariscos" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/cbHuevo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Huevo" />

                    <CheckBox
                        android:id="@+id/cbSoja"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Soja" />
                </LinearLayout>

                <!-- PRECIO TOTAL -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#212121"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="TOTAL"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvPrecioTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0,00 €"
                            android:textColor="#4CAF50"
                            android:textSize="24sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- BOTON CREAR COMANDA -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCrearComanda"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="14dp"
                    android:text="Crear Comanda"
                    android:textSize="16sp"
                    app:cornerRadius="8dp" />

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

</FrameLayout>